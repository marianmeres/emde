<%
const { page, root, parent, _pages, _helpers } = props;
const { relative, children, htmlHead, versionHash } = _helpers;

const childs = children?.(props) ?? [];
const siteTitle = page.meta?.siteTitle || root?.meta?.title || 'Product';
const tagline = page.meta?.tagline || '';
const ctaText = page.meta?.ctaText || 'Get Started';
const ctaHref = page.meta?.ctaHref || '#';
const features = page.meta?.features || [];
%>
<!DOCTYPE html>
<html lang="<%= page.meta?.lang || 'en' %>">
<head>
<%= htmlHead(props, {
	reboot: true,
	seo: page.meta?.site || undefined,
}) %>
<style><%= _helpers.themeTokens?.(props) || '' %></style>
<style>
* { box-sizing: border-box; }
:root {
	--landing-primary: var(--t-color-primary, #4f46e5);
	--landing-primary-fg: var(--t-color-primary-foreground, #fff);
	--landing-accent: var(--t-color-accent, #0891b2);
	--landing-bg: var(--t-color-background, #fff);
	--landing-fg: var(--t-color-foreground, #0f172a);
	--landing-muted: var(--t-color-muted, #f1f5f9);
	--landing-muted-fg: var(--t-color-muted-foreground, #64748b);
	--landing-surface: var(--t-color-surface, #e2e8f0);
	--landing-border: var(--t-color-border, #e2e8f0);
}
body {
	margin: 0;
	font-family: system-ui, -apple-system, sans-serif;
	color: var(--landing-fg);
	background: var(--landing-bg);
	line-height: 1.6;
}
.l-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 1rem 2rem;
	border-bottom: 1px solid var(--landing-border);
}
.l-header a { text-decoration: none; color: inherit; }
.l-logo { font-weight: 700; font-size: 1.25rem; }
.l-nav { display: flex; gap: 1.5rem; align-items: center; }
.l-nav a { font-size: 0.875rem; color: var(--landing-muted-fg); }
.l-nav a:hover { color: var(--landing-fg); }
.l-hero {
	text-align: center;
	padding: 4rem 2rem;
	background: var(--landing-muted);
}
.l-hero h1 {
	font-size: clamp(2rem, 5vw, 3.5rem);
	margin: 0 0 1rem;
	line-height: 1.1;
}
.l-hero p {
	font-size: 1.25rem;
	color: var(--landing-muted-fg);
	max-width: 40ch;
	margin: 0 auto 2rem;
}
.l-hero-svg { max-width: 500px; width: 100%; margin: 2rem auto 0; display: block; }
.l-cta {
	display: inline-block;
	padding: 0.75rem 2rem;
	background: var(--landing-primary);
	color: var(--landing-primary-fg) !important;
	border-radius: 0.5rem;
	text-decoration: none !important;
	font-weight: 600;
	font-size: 1rem;
	border: none;
}
.l-cta:hover { background: var(--t-color-primary-hover, var(--landing-primary)); }
.l-features {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
	gap: 2rem;
	padding: 3rem 2rem;
	max-width: 72rem;
	margin: 0 auto;
}
.l-feature {
	padding: 1.5rem;
	border: 1px solid var(--landing-border);
	border-radius: 0.75rem;
	background: var(--landing-bg);
}
.l-feature h3 { margin: 0 0 0.5rem; font-size: 1.125rem; }
.l-feature p { margin: 0; color: var(--landing-muted-fg); font-size: 0.9rem; }
.l-content {
	max-width: 65ch;
	margin: 0 auto;
	padding: 2rem;
}
.l-children {
	padding: 2rem;
	max-width: 72rem;
	margin: 0 auto;
	border-top: 1px solid var(--landing-border);
}
.l-children ul { list-style: none; padding: 0; display: flex; gap: 1rem; flex-wrap: wrap; }
.l-children a {
	display: block;
	padding: 0.75rem 1.5rem;
	border: 1px solid var(--landing-border);
	border-radius: 0.5rem;
	text-decoration: none;
	color: inherit;
}
.l-children a:hover { background: var(--landing-muted); }
.l-footer {
	padding: 2rem;
	text-align: center;
	color: var(--landing-muted-fg);
	font-size: 0.875rem;
	border-top: 1px solid var(--landing-border);
}
.l-theme-btn {
	background: var(--landing-surface);
	border: 1px solid var(--landing-border);
	border-radius: 0.375rem;
	padding: 0.375rem 0.75rem;
	cursor: pointer;
	font-size: 0.8rem;
	color: var(--landing-fg);
}
.l-theme-btn:hover { background: var(--landing-primary); color: var(--landing-primary-fg); }
</style>
<script>
<%= `// theme-switch v=${versionHash()}` %>
(function(){var K="emde-theme",r=document.documentElement;function g(){return r.classList.contains("dark")?"dark":"light"}function s(m){m==="dark"?r.classList.add("dark"):r.classList.remove("dark");try{sessionStorage.setItem(K,m)}catch(e){}document.dispatchEvent(new CustomEvent("emde-theme-change",{detail:{mode:m}}))}try{if(sessionStorage.getItem(K)==="dark")r.classList.add("dark")}catch(e){}globalThis.__emdeTheme={toggle:function(){s(g()==="dark"?"light":"dark")},set:s,get:g}})();
</script>
</head>
<body>
	<header class="l-header">
		<a class="l-logo" href="<%= relative(page.path, '/') %>/"><%= siteTitle %></a>
		<nav class="l-nav">
			<% for (const p of childs) { %>
				<a href="<%= relative(page.path, p.path) %>/"><%= p.meta?.title || p.path %></a>
			<% } %>
			<button class="l-theme-btn" onclick="__emdeTheme.toggle()">Toggle theme</button>
		</nav>
	</header>
	<% if (tagline || features.length) { %>
		<section class="l-hero">
			<h1><%= page.meta?.title || siteTitle %></h1>
			<% if (tagline) { %><p><%= tagline %></p><% } %>
			<a class="l-cta" href="<%= ctaHref %>"><%= ctaText %></a>
			<svg class="l-hero-svg" viewBox="0 0 500 200" xmlns="http://www.w3.org/2000/svg">
				<defs>
					<linearGradient id="hg" x1="0%" y1="0%" x2="100%" y2="100%">
						<stop offset="0%" stop-color="var(--landing-primary)" stop-opacity="0.2"/>
						<stop offset="100%" stop-color="var(--landing-accent)" stop-opacity="0.2"/>
					</linearGradient>
				</defs>
				<rect width="500" height="200" rx="12" fill="url(#hg)"/>
				<circle cx="120" cy="100" r="40" fill="var(--landing-primary)" opacity="0.3"/>
				<circle cx="250" cy="80" r="55" fill="var(--landing-accent)" opacity="0.25"/>
				<circle cx="380" cy="110" r="35" fill="var(--landing-primary)" opacity="0.2"/>
				<text x="250" y="108" text-anchor="middle" fill="var(--landing-muted-fg)" font-size="14" font-family="system-ui">Illustration placeholder</text>
			</svg>
		</section>
		<% if (features.length) { %>
			<section class="l-features">
				<% for (const f of features) { %>
					<div class="l-feature">
						<h3><%= f.title %></h3>
						<p><%= f.description %></p>
					</div>
				<% } %>
			</section>
		<% } %>
	<% } %>
	<div class="l-content">
		<article><%= page.html %></article>
	</div>
	<% if (childs.length && !tagline) { %>
		<div class="l-children">
			<strong>Pages</strong>
			<ul>
				<% for (const p of childs) { %>
					<li><a href="<%= relative(page.path, p.path) %>/"><%= p.meta?.title || p.path %></a></li>
				<% } %>
			</ul>
		</div>
	<% } %>
	<footer class="l-footer">&copy; <%= new Date().getFullYear() %> <%= siteTitle %></footer>
</body>
</html>