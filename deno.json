{
  "name": "@marianmeres/emde",
  "version": "1.5.1",
  "exports": {
    ".": "./src/mod.ts",
    "./cli": "./src/cli.ts"
  },
  "publish": {
    "exclude": [
      "scripts"
    ]
  },
  "tasks": {
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "example:build": "deno run -A src/cli.ts --indir example/src --outdir example/dist --force --verbose",
    "example-layouts:build": "deno run -A src/cli.ts --indir example-layouts/src --outdir example-layouts/dist --layouts ./example-layouts/layouts --force --verbose",
    "example-layouts:watch": "deno run -A src/cli.ts --indir example-layouts/src --outdir example-layouts/dist --layouts ./example-layouts/layouts --force --verbose --watch",
    "vendor:vanilla": "deno run -A scripts/vendor-vanilla.ts",
    "release": "deno run -A jsr:@marianmeres/deno-release",
    "publish": "deno publish",
    "rp": "deno task release -y && deno task publish",
    "rpm": "deno task release minor -y && deno task publish"
  },
  "imports": {
    "@luca/esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@^0.11.1",
    "@marianmeres/design-tokens": "jsr:@marianmeres/design-tokens@^1.8.0",
    "@marianmeres/item-collection": "jsr:@marianmeres/item-collection@^1.4.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.30",
    "@std/collections": "jsr:@std/collections@^1.2.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/fmt": "jsr:@std/fmt@^1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@std/yaml": "jsr:@std/yaml@^1.1.1",
    "esbuild": "npm:esbuild@^0.28.0",
    "lodash": "npm:lodash@^4.18.1",
    "marked": "npm:marked@^18.0.5"
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 90,
    "indentWidth": 4
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}
