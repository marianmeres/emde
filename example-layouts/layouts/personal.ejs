<%
const { page, root, parent, _pages, _helpers } = props;
const { relative, children, siblings, breadcrumbs, htmlHead, versionHash } = _helpers;

const childs = children?.(props) ?? [];
const sibs = siblings?.(props) ?? [];
const crumbs = breadcrumbs?.(props) ?? [];
const name = root?.meta?.authorName || root?.meta?.title || 'Me';
const bio = root?.meta?.authorBio || '';
const isRoot = page.depth === 0;
%>
<!DOCTYPE html>
<html lang="<%= page.meta?.lang || 'en' %>">
<head>
<%= htmlHead(props, {
	reboot: true,
	seo: page.meta?.site || undefined,
}) %>
<style><%= _helpers.themeTokens?.(props) || '' %></style>
<style>
* { box-sizing: border-box; }
:root {
	--p-primary: var(--t-color-primary, #0d9488);
	--p-accent: var(--t-color-accent, #f59e0b);
	--p-bg: var(--t-color-background, #fff);
	--p-fg: var(--t-color-foreground, #1e293b);
	--p-muted: var(--t-color-muted, #f1f5f9);
	--p-muted-fg: var(--t-color-muted-foreground, #64748b);
	--p-border: var(--t-color-border, #e2e8f0);
}
body {
	margin: 0;
	font-family: 'Georgia', 'Times New Roman', serif;
	color: var(--p-fg);
	background: var(--p-bg);
	line-height: 1.7;
}
.p-wrap { max-width: 42rem; margin: 0 auto; padding: 0 1.5rem; }
.p-header {
	text-align: center;
	padding: 3rem 1.5rem 2rem;
	border-bottom: 1px solid var(--p-border);
}
.p-avatar {
	width: 80px;
	height: 80px;
	margin: 0 auto 1rem;
	display: block;
}
.p-header h1 { margin: 0; font-size: 1.75rem; font-weight: 400; letter-spacing: 0.02em; }
.p-header p { margin: 0.5rem 0 0; color: var(--p-muted-fg); font-size: 0.95rem; }
.p-nav {
	display: flex;
	justify-content: center;
	gap: 1.5rem;
	padding: 1rem 0;
	border-bottom: 1px solid var(--p-border);
	font-family: system-ui, sans-serif;
	font-size: 0.85rem;
}
.p-nav a { text-decoration: none; color: var(--p-muted-fg); }
.p-nav a:hover { color: var(--p-primary); }
.p-breadcrumbs {
	font-family: system-ui, sans-serif;
	font-size: 0.8rem;
	color: var(--p-muted-fg);
	padding: 1rem 0 0;
}
.p-breadcrumbs a { text-decoration: none; color: var(--p-muted-fg); }
.p-breadcrumbs a:hover { color: var(--p-primary); }
.p-content { padding: 2rem 0; }
.p-content h1 { font-size: 1.75rem; font-weight: 400; }
.p-children {
	padding: 1.5rem 0;
	border-top: 1px solid var(--p-border);
	font-family: system-ui, sans-serif;
}
.p-children ul { list-style: none; padding: 0; }
.p-children li { padding: 0.375rem 0; }
.p-children a { text-decoration: none; color: var(--p-primary); }
.p-siblings {
	padding: 1rem 0;
	border-top: 1px solid var(--p-border);
	font-family: system-ui, sans-serif;
	font-size: 0.9rem;
}
.p-siblings ul { list-style: none; padding: 0; display: flex; gap: 1rem; flex-wrap: wrap; }
.p-siblings a { text-decoration: none; color: var(--p-muted-fg); }
.p-siblings a:hover { color: var(--p-primary); }
.p-footer {
	padding: 2rem 0;
	text-align: center;
	color: var(--p-muted-fg);
	font-size: 0.8rem;
	font-family: system-ui, sans-serif;
	border-top: 1px solid var(--p-border);
}
.p-theme-btn {
	background: var(--p-muted);
	border: 1px solid var(--p-border);
	border-radius: 99px;
	padding: 0.25rem 0.75rem;
	cursor: pointer;
	font-size: 0.75rem;
	color: var(--p-fg);
	font-family: system-ui, sans-serif;
}
.p-theme-btn:hover { background: var(--p-primary); color: var(--t-color-primary-foreground, #fff); }
</style>
<script>
<%= `// theme-switch v=${versionHash()}` %>
(function(){var K="emde-theme",r=document.documentElement;function g(){return r.classList.contains("dark")?"dark":"light"}function s(m){m==="dark"?r.classList.add("dark"):r.classList.remove("dark");try{sessionStorage.setItem(K,m)}catch(e){}document.dispatchEvent(new CustomEvent("emde-theme-change",{detail:{mode:m}}))}try{if(sessionStorage.getItem(K)==="dark")r.classList.add("dark")}catch(e){}globalThis.__emdeTheme={toggle:function(){s(g()==="dark"?"light":"dark")},set:s,get:g}})();
</script>
</head>
<body>
	<header class="p-header">
		<svg class="p-avatar" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
			<circle cx="40" cy="40" r="40" fill="var(--p-muted)"/>
			<circle cx="40" cy="32" r="14" fill="var(--p-primary)" opacity="0.5"/>
			<ellipse cx="40" cy="68" rx="24" ry="18" fill="var(--p-primary)" opacity="0.3"/>
		</svg>
		<h1><a href="<%= relative(page.path, '/') %>/" style="text-decoration:none;color:inherit"><%= name %></a></h1>
		<% if (bio) { %><p><%= bio %></p><% } %>
	</header>
	<div class="p-wrap">
		<nav class="p-nav">
			<% const rootChildren = root ? (_helpers.children?.({ ...props, page: root }) ?? []) : []; %>
			<% for (const p of rootChildren) { %>
				<a href="<%= relative(page.path, p.path) %>/"><%= p.meta?.title || p.path %></a>
			<% } %>
			<button class="p-theme-btn" onclick="__emdeTheme.toggle()">theme</button>
		</nav>
		<% if (crumbs.length > 1) { %>
			<div class="p-breadcrumbs">
				<% for (const [i, p] of crumbs.entries()) { %>
					<% if (i) { %> &rsaquo; <% } %>
					<% if (i === crumbs.length - 1) { %><%= p.meta?.title || p.path %><% } else { %><a href="<%= relative(page.path, p.path) %>/"><%= p.meta?.title || p.path %></a><% } %>
				<% } %>
			</div>
		<% } %>
		<main class="p-content">
			<article><%= page.html %></article>
		</main>
		<% if (childs.length) { %>
			<div class="p-children">
				<ul>
					<% for (const p of childs) { %>
						<li><a href="<%= relative(page.path, p.path) %>/"><%= p.meta?.title || p.path %></a></li>
					<% } %>
				</ul>
			</div>
		<% } %>
		<% if (sibs.length) { %>
			<div class="p-siblings">
				<ul>
					<% for (const p of sibs) { %>
						<li><a href="<%= relative(page.path, p.path) %>/"><%= p.meta?.title || p.path %></a></li>
					<% } %>
				</ul>
			</div>
		<% } %>
		<footer class="p-footer">&copy; <%= new Date().getFullYear() %> <%= name %></footer>
	</div>
</body>
</html>