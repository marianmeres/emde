{
  "name": "@marianmeres/emde",
  "version": "1.2.2",
  "exports": {
    ".": "./src/mod.ts",
    "./cli": "./src/cli.ts"
  },
  "tasks": {
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "build:example": "deno run -A src/cli.ts --indir example/src --outdir example/dist --force --verbose",
    "release": "deno run -A jsr:@marianmeres/deno-release",
    "publish": "deno publish",
    "rp": "deno task release -y && deno task publish",
    "rpm": "deno task release minor -y && deno task publish"
  },
  "imports": {
    "@marianmeres/item-collection": "jsr:@marianmeres/item-collection@^1.3.5",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/collections": "jsr:@std/collections@^1.1.6",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/fmt": "jsr:@std/fmt@^1.0.9",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "lodash": "npm:lodash@^4.17.23",
    "marked": "npm:marked@^17.0.4"
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 90,
    "indentWidth": 4
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}
