<%
const { page, root, parent, _pages, _helpers } = props;
const { relative, children, siblings, breadcrumbs, htmlHead, versionHash } = _helpers;

const childs = children?.(props) ?? [];
const sibs = siblings?.(props) ?? [];
const crumbs = breadcrumbs?.(props) ?? [];
const siteTitle = root?.meta?.title || 'News';
const featured = childs[0] || null;
const rest = childs.slice(1);
const isArticle = page.depth > 0 && childs.length === 0;
%>
<!DOCTYPE html>
<html lang="<%= page.meta?.lang || 'en' %>">
<head>
<%= htmlHead(props, {
	reboot: true,
	seo: page.meta?.site || undefined,
}) %>
<style><%= _helpers.themeTokens?.(props) || '' %></style>
<style>
* { box-sizing: border-box; }
:root {
	--n-primary: var(--t-color-primary, #dc2626);
	--n-primary-fg: var(--t-color-primary-foreground, #fff);
	--n-accent: var(--t-color-accent, #0284c7);
	--n-bg: var(--t-color-background, #fff);
	--n-fg: var(--t-color-foreground, #0f172a);
	--n-muted: var(--t-color-muted, #f8fafc);
	--n-muted-fg: var(--t-color-muted-foreground, #64748b);
	--n-border: var(--t-color-border, #e2e8f0);
	--n-surface: var(--t-color-surface, #f1f5f9);
}
body {
	margin: 0;
	font-family: system-ui, -apple-system, sans-serif;
	color: var(--n-fg);
	background: var(--n-bg);
	line-height: 1.6;
}
.n-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 0.75rem 2rem;
	border-bottom: 3px solid var(--n-primary);
}
.n-header a { text-decoration: none; color: inherit; }
.n-title { font-weight: 900; font-size: 1.5rem; text-transform: uppercase; letter-spacing: -0.02em; }
.n-header-right { display: flex; gap: 1rem; align-items: center; }
.n-section-bar {
	display: flex;
	gap: 1.5rem;
	padding: 0.5rem 2rem;
	border-bottom: 1px solid var(--n-border);
	font-size: 0.85rem;
	font-weight: 600;
	text-transform: uppercase;
	letter-spacing: 0.03em;
	overflow-x: auto;
}
.n-section-bar a { text-decoration: none; color: var(--n-muted-fg); white-space: nowrap; }
.n-section-bar a:hover { color: var(--n-primary); }
.n-wrap { max-width: 80rem; margin: 0 auto; padding: 2rem; }
.n-breadcrumbs {
	font-size: 0.8rem;
	color: var(--n-muted-fg);
	margin-bottom: 1rem;
}
.n-breadcrumbs a { text-decoration: none; color: var(--n-muted-fg); }
.n-breadcrumbs a:hover { color: var(--n-primary); }
.n-featured {
	display: flex;
	gap: 2rem;
	margin-bottom: 2rem;
	padding-bottom: 2rem;
	border-bottom: 1px solid var(--n-border);
	flex-wrap: wrap;
}
.n-featured-img { flex: 1.5; min-width: 300px; }
.n-featured-body { flex: 1; min-width: 250px; }
.n-featured-body h2 { margin: 0 0 0.5rem; font-size: 1.75rem; line-height: 1.2; }
.n-featured-body h2 a { text-decoration: none; color: inherit; }
.n-featured-body h2 a:hover { color: var(--n-primary); }
.n-featured-body p { color: var(--n-muted-fg); }
.n-featured-date { font-size: 0.8rem; color: var(--n-muted-fg); }
.n-grid {
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
	gap: 1.5rem;
}
.n-card {
	border: 1px solid var(--n-border);
	border-radius: 0.5rem;
	overflow: hidden;
	text-decoration: none;
	color: inherit;
	display: block;
	transition: box-shadow 0.15s;
}
.n-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.n-card-img { width: 100%; aspect-ratio: 16/9; display: block; }
.n-card-body { padding: 0.75rem 1rem; }
.n-card-body h3 { margin: 0 0 0.25rem; font-size: 0.95rem; line-height: 1.3; }
.n-card-body p { margin: 0; font-size: 0.8rem; color: var(--n-muted-fg); }
.n-card-date { font-size: 0.75rem; color: var(--n-muted-fg); margin-top: 0.375rem; }
.n-article {
	max-width: 52rem;
	margin: 0 auto;
}
.n-article h1 { font-size: 2rem; margin: 0 0 0.5rem; line-height: 1.2; }
.n-article-meta { font-size: 0.85rem; color: var(--n-muted-fg); margin-bottom: 2rem; display: flex; gap: 1rem; }
.n-related {
	max-width: 52rem;
	margin: 2rem auto 0;
	padding-top: 1.5rem;
	border-top: 1px solid var(--n-border);
}
.n-related h3 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--n-muted-fg); margin: 0 0 0.75rem; }
.n-related ul { list-style: none; padding: 0; }
.n-related li { padding: 0.25rem 0; }
.n-related a { text-decoration: none; color: var(--n-accent); }
.n-footer {
	padding: 2rem;
	text-align: center;
	color: var(--n-muted-fg);
	font-size: 0.8rem;
	border-top: 1px solid var(--n-border);
	margin-top: 3rem;
}
.n-theme-btn {
	background: var(--n-muted);
	border: 1px solid var(--n-border);
	border-radius: 0.375rem;
	padding: 0.25rem 0.75rem;
	cursor: pointer;
	font-size: 0.75rem;
	color: var(--n-fg);
}
.n-theme-btn:hover { background: var(--n-primary); color: var(--t-color-primary-foreground, #fff); }
</style>
<script>
<%= `// theme-switch v=${versionHash()}` %>
(function(){var K="emde-theme",r=document.documentElement;function g(){return r.classList.contains("dark")?"dark":"light"}function s(m){m==="dark"?r.classList.add("dark"):r.classList.remove("dark");try{sessionStorage.setItem(K,m)}catch(e){}document.dispatchEvent(new CustomEvent("emde-theme-change",{detail:{mode:m}}))}try{if(sessionStorage.getItem(K)==="dark")r.classList.add("dark")}catch(e){}globalThis.__emdeTheme={toggle:function(){s(g()==="dark"?"light":"dark")},set:s,get:g}})();
</script>
</head>
<body>
	<header class="n-header">
		<a class="n-title" href="<%= relative(page.path, '/') %>/"><%= siteTitle %></a>
		<div class="n-header-right">
			<button class="n-theme-btn" onclick="__emdeTheme.toggle()">Theme</button>
		</div>
	</header>
	<% const rootChildren = root ? (_helpers.children?.({ ...props, page: root }) ?? []) : []; %>
	<% if (rootChildren.length) { %>
		<nav class="n-section-bar">
			<% for (const p of rootChildren) { %>
				<a href="<%= relative(page.path, p.path) %>/"><%= p.meta?.title || p.path %></a>
			<% } %>
		</nav>
	<% } %>
	<div class="n-wrap">
		<% if (crumbs.length > 1) { %>
			<nav class="n-breadcrumbs">
				<% for (const [i, p] of crumbs.entries()) { %>
					<% if (i) { %> &rsaquo; <% } %>
					<% if (i === crumbs.length - 1) { %><%= p.meta?.title || p.path %><% } else { %><a href="<%= relative(page.path, p.path) %>/"><%= p.meta?.title || p.path %></a><% } %>
				<% } %>
			</nav>
		<% } %>
		<% if (isArticle) { %>
			<div class="n-article">
				<% if (page.meta?.date || page.meta?.author) { %>
					<div class="n-article-meta">
						<% if (page.meta?.date) { %><span><%= page.meta.date %></span><% } %>
						<% if (page.meta?.author) { %><span>by <%= page.meta.author %></span><% } %>
					</div>
				<% } %>
				<article><%= page.html %></article>
			</div>
			<% if (sibs.length) { %>
				<aside class="n-related">
					<h3>More stories</h3>
					<ul>
						<% for (const p of sibs) { %>
							<li><a href="<%= relative(page.path, p.path) %>/"><%= p.meta?.title || p.path %></a></li>
						<% } %>
					</ul>
				</aside>
			<% } %>
		<% } else { %>
			<article><%= page.html %></article>
			<% if (featured) { %>
				<section class="n-featured">
					<div class="n-featured-img">
						<svg viewBox="0 0 600 340" xmlns="http://www.w3.org/2000/svg" style="width:100%;border-radius:0.5rem">
							<rect width="600" height="340" fill="var(--n-muted)"/>
							<rect x="40" y="40" width="520" height="260" rx="8" fill="var(--n-primary)" opacity="0.08"/>
							<text x="300" y="178" text-anchor="middle" fill="var(--n-muted-fg)" font-size="14" font-family="system-ui">Featured image</text>
						</svg>
					</div>
					<div class="n-featured-body">
						<h2><a href="<%= relative(page.path, featured.path) %>/"><%= featured.meta?.title || featured.path %></a></h2>
						<% if (featured.meta?.description) { %><p><%= featured.meta.description %></p><% } %>
						<% if (featured.meta?.date) { %><span class="n-featured-date"><%= featured.meta.date %></span><% } %>
					</div>
				</section>
			<% } %>
			<% if (rest.length) { %>
				<div class="n-grid">
					<% for (const [ci, p] of rest.entries()) { %>
						<a class="n-card" href="<%= relative(page.path, p.path) %>/">
							<svg class="n-card-img" viewBox="0 0 400 225" xmlns="http://www.w3.org/2000/svg">
								<rect width="400" height="225" fill="var(--n-muted)"/>
								<rect x="<%= 40 + (ci * 25) % 80 %>" y="30" width="<%= 200 + (ci * 30) % 100 %>" height="165" rx="6" fill="var(--n-accent)" opacity="<%= 0.06 + ci * 0.03 %>"/>
								<text x="200" y="120" text-anchor="middle" fill="var(--n-muted-fg)" font-size="12" font-family="system-ui"><%= p.meta?.title || p.path %></text>
							</svg>
							<div class="n-card-body">
								<h3><%= p.meta?.title || p.path %></h3>
								<% if (p.meta?.description) { %><p><%= p.meta.description %></p><% } %>
								<% if (p.meta?.date) { %><div class="n-card-date"><%= p.meta.date %></div><% } %>
							</div>
						</a>
					<% } %>
				</div>
			<% } %>
		<% } %>
	</div>
	<footer class="n-footer">&copy; <%= new Date().getFullYear() %> <%= siteTitle %></footer>
</body>
</html>